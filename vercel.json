{
  "version": 2,
  "builds": [
    {
      "src": "api/transfer.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/transfer",
      "dest": "api/transfer.py"
    },
    {
      "src": "/transfer",
      "dest": "api/transfer.py"
    },
    {
      "src": "/(.*)",
      "dest": "api/transfer.py"
    }
  ]
}
